{
  "name": "@stackline/angular2-multiselect-dropdown",
  "version": "14.0.1",
  "scripts": {
    "ng": "ng",
    "start": "cd docs-src/angular-21 && npm start",
    "build": "npm run build-package",
    "test": "ng test",
    "lint": "ng lint",
    "build-sass": "npx sass --load-path=scss projects/@stackline/angular2-multiselect-dropdown-lib/themes/default.theme.scss:projects/@stackline/angular2-multiselect-dropdown-lib/themes/default.theme.css projects/@stackline/angular2-multiselect-dropdown-lib/themes/custom.theme.scss:projects/@stackline/angular2-multiselect-dropdown-lib/themes/custom.theme.css",
    "build-package:raw": "npm run build-sass && npx ng-packagr -p projects/@stackline/angular2-multiselect-dropdown-lib/ng-package.json",
    "build-package": "node scripts/release-line.mjs",
    "build-package:line": "node scripts/release-line.mjs",
    "docs:install:angular-14": "cd docs-src/angular-14 && npm install --ignore-scripts",
    "build:docs:angular-14": "cd docs-src/angular-14 && npm run build",
    "docs:install:angular-19": "cd docs-src/angular-19 && npm install --ignore-scripts",
    "build:docs:angular-19": "cd docs-src/angular-19 && npm run build",
    "docs:install:angular-20": "cd docs-src/angular-20 && npm install --ignore-scripts",
    "build:docs:angular-20": "cd docs-src/angular-20 && npm run build",
    "docs:install:angular-21": "cd docs-src/angular-21 && npm install --ignore-scripts",
    "build:docs:angular-21": "cd docs-src/angular-21 && npm run build",
    "build:docs": "npm run build:docs:angular-21",
    "github-pages": "npm run build:docs",
    "publish-npm": "node scripts/release-line.mjs --publish",
    "publish-npm:line": "node scripts/release-line.mjs --publish"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.7",
    "@angular/cdk": "~21.2.5",
    "@angular/common": "~21.2.7",
    "@angular/compiler": "~21.2.7",
    "@angular/core": "~21.2.7",
    "@angular/forms": "~21.2.7",
    "@angular/localize": "~21.2.7",
    "@angular/platform-browser": "~21.2.7",
    "@angular/platform-browser-dynamic": "~21.2.7",
    "@angular/router": "~21.2.7",
    "@angular/service-worker": "~21.2.7",
    "@ng-bootstrap/ng-bootstrap": "~20.0.0",
    "@popperjs/core": "^2.11.8",
    "@tweenjs/tween.js": "^25.0.0",
    "bootstrap": "^5.3.8",
    "highlight.js": "^11.11.1",
    "ng2-adsense": "^14.0.0",
    "ngx-highlightjs": "^14.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.5.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.6",
    "@angular/cli": "~21.2.6",
    "@angular/compiler-cli": "~21.2.7",
    "@types/highlight.js": "^10.1.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.1",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "~21.2.2",
    "sass": "^1.83.0",
    "typescript": "~5.9.3"
  }
}
